#!/usr/bin/env bash
# Adds the ALU public key to the ubuntu user on the remote server

SERVER_IP="54.227.137.95"
ALU_KEY="ssh-rsa "

# Ensure our local private key file exists before connecting
if [ ! -f ~/.ssh/school ]; then
    echo "Error: Private key ~/.ssh/school not found."
    exit 1
fi

echo "Connecting to remote server to install keys..."

# Send the setup sequence directly to the remote server via SSH
ssh -i ~/.ssh/school ubuntu@"$SERVER_IP" "mkdir -p ~/.ssh && echo '$ALU_KEY' >> ~/.ssh/authorized_keys && chmod 700 ~/.ssh && chmod 600 ~/.ssh/authorized_keys"

echo "Testing SSH connection..."
ssh -i ~/.ssh/school ubuntu@"$SERVER_IP" "echo 'SSH login successful!'"
