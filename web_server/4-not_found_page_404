#!/usr/bin/env bash
# Configures Nginx with a custom 404 page returning the specified text string

apt-get update -y
apt-get install nginx -y

echo "Holberton School for the win!" > /var/www/html/index.nginx-debian.html

# Create the custom 404 page
echo "Ceci n'est pas une page" > /var/www/html/custom_404.html

CONFIG_FILE="/etc/nginx/sites-available/default"

# Inject the error_page definition and map it to return the custom 404 file properly
sed -i "/server_name _;/a \\\t/custom_404.html;\n\tlocation = /custom_404.html {\n\t\troot /var/www/html;\n\t\tinternal;\n\t}" "$CONFIG_FILE"
sed -i "/server_name _;/a \\\terror_page 404" "$CONFIG_FILE"

service nginx restart
